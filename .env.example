# Copy to .env (gitignored) and fill in. Never commit real secrets.

# Slack Incoming Webhook — presence notifications are posted here.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# GitHub token for the github sink (contents: read/write on the status repo).
# Use a fine-grained PAT scoped to ONE private repo.
GITHUB_TOKEN=

# eero one-time login helpers (see README). Either provide your login id and
# use the interactive code prompt, or paste a captured browser session token.
EERO_LOGIN=
# EERO_SESSION=123456|abcdef...

# Ring token file location (created by --ring-login).
# RING_TOKEN_FILE=/home/you/.propertypresence_ring_token.json

# Alexa announcements (choose one path in config: notify_me or webhook)
ALEXA_NOTIFYME_TOKEN=
ALEXA_WEBHOOK_URL=

# Logging
LOG_LEVEL=INFO
